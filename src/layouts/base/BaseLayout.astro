---
import Analytics from "@vercel/analytics/astro";
import stylesheetUrl from "../../styles/global.css?url";
import { appearanceConfig, effectsConfig, siteConfig, textmodeConfig } from "../../config";
import { appearanceCssVariables } from "../../modules/textmode/core/css-vars";

type Props = {
  title?: string;
  tabTitle?: string;
  description?: string;
  preloadCjk?: boolean;
  pageType?: "website" | "article";
  publishedTime?: Date;
};

const pageTitle = Astro.props.title ? `${Astro.props.title} :: ${siteConfig.name}` : siteConfig.name;
const tabTitle = Astro.props.tabTitle ?? siteConfig.name;
const description = Astro.props.description ?? siteConfig.description;
const preloadCjk = Astro.props.preloadCjk ?? false;
const pageType = Astro.props.pageType ?? "website";
const canonicalUrl = new URL(Astro.url.pathname, Astro.site ?? Astro.url).toString();
const rssUrl = new URL("/rss.xml", Astro.site ?? Astro.url).toString();
const ogImageUrl = new URL("/og.png", Astro.site ?? Astro.url).toString();
const appearanceCss = appearanceCssVariables(appearanceConfig);
const mobileFitBreakpoint = textmodeConfig.mobileFitBreakpoint;
const particlesEnabled = effectsConfig.particles.enable;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="robots" content="index,follow" />
    <meta name="theme-color" content={appearanceConfig.colors.homeBackground} />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="icon" href="/favicon-32.png" sizes="32x32" type="image/png" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="alternate" type="application/rss+xml" title={`${siteConfig.name} RSS`} href={rssUrl} />
    <link rel="me" href="https://github.com/dylanszejnblum" />
    <link rel="me" href="https://twitter.com/dylansz_" />
    <meta property="og:site_name" content={siteConfig.name} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content={pageType} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={siteConfig.description} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />
    {
      Astro.props.publishedTime && (
        <meta property="article:published_time" content={Astro.props.publishedTime.toISOString()} />
      )
    }
    <link rel="stylesheet" href={stylesheetUrl} />
    <style set:html={appearanceCss}></style>
    <link
      rel="preload"
      href={appearanceConfig.fonts.asciiUrl}
      as="font"
      type={`font/${appearanceConfig.fonts.asciiFormat}`}
      crossorigin
    />
    {preloadCjk && <link rel="preload" href="/assets/cjk/wqy-cjk-body.png" as="image" />}
    {preloadCjk && <link rel="preload" href="/assets/cjk/wqy-cjk-link.png" as="image" />}
    <title>{tabTitle}</title>
  </head>
  <body data-mobile-fit-breakpoint={mobileFitBreakpoint} data-particles-enabled={particlesEnabled}>
    <slot />
    <Analytics />
    <script>
      import { installTextmodeBootstrap } from "../../modules/textmode/bootstrap/install";

      installTextmodeBootstrap();
    </script>
  </body>
</html>
